{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "newsletterName": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "issueNumber": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "updateDate": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "anyOf": [
        {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "category": {
      "anyOf": [
        {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "sticky": {
      "anyOf": [
        {
          "default": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ]
    },
    "mathjax": {
      "anyOf": [
        {
          "default": false,
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "mermaid": {
      "anyOf": [
        {
          "default": false,
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "draft": {
      "anyOf": [
        {
          "default": false,
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "comment": {
      "anyOf": [
        {
          "default": true,
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}