---
import BlogPostMeta from "../../components/BlogPostMeta.astro";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { SITE_URL } from "../../config";
import { getCollection, getEntry } from "astro:content";
import Renderer from "src/components/Renderer.astro";

export async function getStaticPaths() {

  const mektups = await getCollection('newsletter', ({ data }) =>  {
    if(!data.tags) {
      return false;
    }
    return data.tags.includes('mektup');
  });

  const mediations = await getCollection('newsletter', ({ data }) =>  {
    if(!data.tags) {
      return false;
    }
    return data.tags.includes('mediations');
  });

  // we don't want to generate pages for posts that link to external websites
  const filteredNewsletters = mektups
    .filter((p) => p.data.draft !== true)

  return filteredNewsletters.map((post) => {
    return { params: { slug: post.slug }, props: { post } };
  });
}

const { slug } = Astro.params;
console.log("SLUG", slug);

if (typeof slug !== "string") {
  throw Error(`slug should be string. Received: ${slug}`);
}

const post = await getEntry('newsletter', slug);

if (post === undefined) {
  return Astro.redirect("/404");
}

const { Content } = await post.render();

const ogImageAbsoluteUrl =
  post.data.external !== true && post.data.ogImagePath
    ? new URL(post.data.ogImagePath, SITE_URL).toString()
    : undefined;

const canonicalURL =
post.data.external !== true && post.data.canonicalUrl
  ? new URL(post.data.canonicalUrl, SITE_URL).toString()
  : undefined;
---

<ContentLayout
  title={post.data.title}
  date={post.data.date}
  updateDate={post.data.updateDate}
  slug={`${slug}`}
  external={post.data.external}
  externalUrl={post.data.external ? post.data.externalUrl : ""}
  >
  <BlogPostMeta
    title={post.data.title}
    description={post.data.external ? undefined : post.data.description}
    publishDate={post.data.date.toISOString()}
    updateDate={post.data.updateDate.toISOString()}
    pagePath={`${slug}`}
    ogImageAbsoluteUrl={ogImageAbsoluteUrl}
    canonicalUrl={canonicalURL}
    slot="meta"
  />
  <Renderer content={ Content } slot="content" />
</ContentLayout>